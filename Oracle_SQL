CREATE TABLE TransportRoute (
  routeId        VARCHAR2(20)  PRIMARY KEY,
  routeName      VARCHAR2(100) NOT NULL,
  routeType      VARCHAR2(30)  NOT NULL,
  city           VARCHAR2(50)  NOT NULL,
  operationalStatus VARCHAR2(20) DEFAULT 'ACTIVE'
    CHECK (operationalStatus IN ('ACTIVE','INACTIVE'))
);

CREATE TABLE Vehicle (
  vehicleId      VARCHAR2(20)  PRIMARY KEY,
  vehicleNumber  VARCHAR2(20)  UNIQUE NOT NULL,
  vehicleType    VARCHAR2(30)  NOT NULL,
  assignedRoute  VARCHAR2(20)  REFERENCES TransportRoute(routeId),
  vehicleStatus  VARCHAR2(20)  DEFAULT 'ACTIVE'
    CHECK (vehicleStatus IN ('ACTIVE','INACTIVE'))
);
CREATE TABLE TrafficRecord (
  trafficId      VARCHAR2(20)  PRIMARY KEY,
  routeId        VARCHAR2(20)  REFERENCES TransportRoute(routeId),
  congestionLevel NUMBER(3)    CHECK (congestionLevel BETWEEN 0 AND 100),
  recordedAt     TIMESTAMP     DEFAULT SYSTIMESTAMP,
  trafficStatus  VARCHAR2(20)  NOT NULL
);

CREATE TABLE PassengerTrip (
  tripId         VARCHAR2(20)  PRIMARY KEY,
  vehicleId      VARCHAR2(20)  REFERENCES Vehicle(vehicleId),
  passengerCount NUMBER        CHECK (passengerCount > 0),
  tripDate       DATE          NOT NULL,
  tripStatus     VARCHAR2(20)  DEFAULT 'COMPLETED'
);

CREATE TABLE TrafficAlert (
  alertId        VARCHAR2(20)  PRIMARY KEY,
  routeId        VARCHAR2(20)  REFERENCES TransportRoute(routeId),
  alertReason    VARCHAR2(200),
  alertSeverity  VARCHAR2(20)  CHECK (alertSeverity IN ('LOW','MEDIUM','HIGH')),
  alertStatus    VARCHAR2(20)  DEFAULT 'OPEN'
);


